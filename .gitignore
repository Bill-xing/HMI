.DS_Store
Thumbs.db

# Qt Creator / build output
*.pro.user
*.pro.user.*
.qmake.stash
Makefile
Makefile.*
build-*/
dist/
debug/
release/
*.o
*.obj
*.exe
*.dll

# IDE files
.idea/
.vscode/

# Python cache / virtual environments
__pycache__/
*.py[cod]
.venv/
venv/
env/

# Runtime output and local config
config.json
segmented_image.png
logs/*
!logs/.gitkeep
scripts/hmi_local_env.sh
